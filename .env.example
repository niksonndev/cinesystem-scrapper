# Telegram (para npm run telegram)
# Crie um bot em https://t.me/BotFather e use o token abaixo.
# Chat ID: envie uma mensagem ao bot e veja em https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=

# Opcional: notas IMDb e Rotten Tomatoes nos filmes
# Obtenha uma chave gratuita em https://www.omdbapi.com/apikey.aspx
# OMDb_API_KEY=
